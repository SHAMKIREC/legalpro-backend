# Backend environment template
NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:your_secure_password@localhost:5432/legalpro

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secrets (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=your_256_bit_random_secret_here
JWT_REFRESH_SECRET=your_different_256_bit_random_secret_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# API Base URL
API_BASE_URL=https://api.legalpro.ru

# CORS Whitelist (comma-separated)
CORS_WHITELIST=https://legalpro.ru,https://www.legalpro.ru,https://t.me

# Storage
STORAGE_PATH=/app/storage

# Optional: Payment Provider
YOOKASSA_SHOP_ID=your_shop_id
YOOKASSA_API_KEY=your_api_key